# Rigol Oscilloscope Connection Settings
# Scope IP address or hostname (required - found under Utility > IO on the scope)
RIGOL_HOST=192.168.1.100

# SCPI socket port
RIGOL_PORT=5555

# I/O timeout, in seconds
RIGOL_TIMEOUT=10

# MCP Server Transport: stdio (local) or streamable-http (Docker/HTTP)
MCP_TRANSPORT=streamable-http

# HTTP bind address/port (only used when MCP_TRANSPORT=streamable-http)
MCP_HOST=0.0.0.0
MCP_PORT=8000

# Optional: Enable raw SCPI escape hatch command (set to "1" to enable, "0" to disable)
# WARNING: Arbitrary SCPI can leave the scope in any state, so this is opt-in only
RIGOL_ENABLE_SCPI_RAW=0
