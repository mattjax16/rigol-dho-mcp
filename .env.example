# Scope IP address or hostname (required)
RIGOL_HOST=192.168.1.100

# SCPI socket port
RIGOL_PORT=5555

# I/O timeout, in seconds
RIGOL_TIMEOUT=10

# Transport: stdio (local) or streamable-http (Docker)
MCP_TRANSPORT=stdio

# HTTP bind address/port (only used when MCP_TRANSPORT=streamable-http)
MCP_HOST=0.0.0.0
MCP_PORT=8000
